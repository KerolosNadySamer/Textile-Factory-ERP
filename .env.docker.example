# Copy the values you need into the project's .env file before starting Compose.
# APP_KEY must be generated and must never be committed.
APP_KEY=
APP_URL=http://localhost:8080

# Docker-only database credentials. Change these outside local development.
DOCKER_DB_DATABASE=textile_erp
DOCKER_DB_USERNAME=textile_user
DOCKER_DB_PASSWORD=local_textile_password
DOCKER_DB_ROOT_PASSWORD=local_root_password

DOCKER_HTTP_PORT=8080
DOCKER_MYSQL_PORT=3307
DOCKER_REDIS_PORT=6380
